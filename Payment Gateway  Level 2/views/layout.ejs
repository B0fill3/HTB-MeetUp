<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title><%= title || "MeetEvents - Tienda de Entradas" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css"
    />
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: radial-gradient(circle at top left, #e5f6ff, #ffffff);
        color: #111827;
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        padding: 1rem 2rem;
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header a.brand {
        color: #0f766e;
        font-weight: 800;
        text-decoration: none;
        letter-spacing: 0.08em;
      }
      header nav a {
        color: #4b5563;
        margin-left: 1rem;
        text-decoration: none;
        font-size: 0.9rem;
      }
      header nav a:hover {
        color: #0f766e;
      }
      main {
        flex: 1;
        padding: 2rem 1.5rem 3rem;
        max-width: 960px;
        margin: 0 auto;
      }
      .event-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.25rem;
        margin-top: 1.25rem;
      }
      .event-card {
        position: relative;
        border-radius: 1rem;
        padding: 1.25rem 1.35rem;
        background: linear-gradient(135deg, #ffffff, #f9fafb);
        border: 1px solid #e5e7eb;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        overflow: hidden;
      }
      .event-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        background: rgba(14, 148, 136, 0.08);
        color: #0f766e;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        margin-bottom: 0.45rem;
      }
      .event-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 600;
        color: #111827;
      }
      .event-meta {
        margin-top: 0.35rem;
        font-size: 0.85rem;
        color: #6b7280;
      }
      .event-footer {
        margin-top: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .event-price {
        font-size: 0.95rem;
        font-weight: 600;
        color: #0f172a;
      }
      .event-price span {
        font-size: 0.8rem;
        color: #6b7280;
      }
      .summary-card {
        margin-top: 0.75rem;
        padding: 0.9rem 1rem;
        border-radius: 0.9rem;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
      }
      .summary-card-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: #111827;
        margin-bottom: 0.25rem;
      }
      .summary-card-body {
        font-size: 0.9rem;
        color: #4b5563;
      }
      .card {
        background: #ffffff;
        border-radius: 1rem;
        padding: 1.5rem 1.75rem;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        border: 1px solid #e5e7eb;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1.2rem;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: background 0.15s ease, transform 0.08s ease,
          box-shadow 0.15s ease;
      }
      .btn-primary {
        background: linear-gradient(135deg, #0ee966, #22c55e);
        color: #ffffff;
        box-shadow: 0 6px 16px rgba(34, 197, 94, 0.35);
      }
      .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 25px rgba(56, 248, 178, 0.5);
      }
      .btn-secondary {
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
      }
      .btn-secondary:hover {
        background: #e5e7eb;
      }
      .field {
        margin-bottom: 1rem;
      }
      label {
        display: block;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
        color: #6b7280;
      }
      input,
      select {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #111827;
        font-size: 0.95rem;
      }
      input:focus,
      select:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 1px rgba(14, 165, 233, 0.4);
      }
      footer {
        padding: 1rem 2rem;
        font-size: 0.8rem;
        color: #9ca3af;
        text-align: center;
        border-top: 1px solid #e5e7eb;
        background: #ffffff;
      }
      code {
        background: #f3f4f6;
        padding: 0.15rem 0.35rem;
        border-radius: 0.35rem;
        font-size: 0.85rem;
      }
      .badge {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .badge-info {
        background: rgba(59, 130, 246, 0.08);
        color: #1d4ed8;
      }
      .badge-danger {
        background: rgba(239, 68, 68, 0.08);
        color: #b91c1c;
      }
      .badge-success {
        background: rgba(34, 197, 94, 0.08);
        color: #15803d;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th,
      td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #1f2937;
        text-align: left;
      }
      th {
        font-size: 0.8rem;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      tr:last-child td {
        border-bottom: none;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="brand">MEETEVENTS</a>
      <nav>
        <a href="/">Eventos</a>
        <a href="/admin/orders">Pedidos</a>
      </nav>
    </header>
    <main>
      <% if (typeof contentTemplate !== 'undefined') { %>
        <%- include(contentTemplate) %>
      <% } %>
    </main>
    <footer>
      MeetEvents · 2026
    </footer>
  </body>
</html>

