<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title><%= title || "MeetEvents - Tienda de Entradas" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css"
    />
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: #0f172a;
        color: #f8fafc;
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        padding: 1rem 2rem;
        background: #1e293b;
        border-bottom: 2px solid #f97316;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header a.brand {
        color: #f97316;
        font-weight: 800;
        text-decoration: none;
        letter-spacing: 0.08em;
      }
      header nav a {
        color: #cbd5e1;
        margin-left: 1rem;
        text-decoration: none;
        font-size: 0.9rem;
      }
      header nav a:hover {
        color: #f97316;
      }
      main {
        flex: 1;
        padding: 2rem 1.5rem 3rem;
        max-width: 960px;
        margin: 0 auto;
      }
      .event-grid {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin-top: 1.25rem;
      }
      .event-card {
        position: relative;
        border-radius: 1rem;
        padding: 0;
        background: #1e293b;
        border: 1px solid #334155;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .event-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-bottom: 1px solid #334155;
      }
      .event-content {
        padding: 1.25rem 1.35rem;
      }
      .event-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        background: rgba(249, 115, 22, 0.2);
        color: #fb923c;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        margin-bottom: 0.45rem;
      }
      .event-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 600;
        color: #f8fafc;
      }
      .event-meta {
        margin-top: 0.35rem;
        font-size: 0.85rem;
        color: #94a3b8;
      }
      .event-footer {
        margin-top: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .event-price {
        font-size: 0.95rem;
        font-weight: 600;
        color: #f97316;
      }
      .event-price span {
        font-size: 0.8rem;
        color: #94a3b8;
      }
      .summary-card {
        margin-top: 0.75rem;
        padding: 0.9rem 1rem;
        border-radius: 0.9rem;
        background: #334155;
        border: 1px solid #475569;
      }
      .summary-card-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: #f8fafc;
        margin-bottom: 0.25rem;
      }
      .summary-card-body {
        font-size: 0.9rem;
        color: #cbd5e1;
      }
      .card {
        background: #1e293b;
        border-radius: 1rem;
        padding: 1.5rem 1.75rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        border: 1px solid #334155;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1.2rem;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: background 0.15s ease, transform 0.08s ease,
          box-shadow 0.15s ease;
      }
      .btn-primary {
        background: #f97316;
        color: #ffffff;
        box-shadow: 0 6px 16px rgba(249, 115, 22, 0.35);
      }
      .btn-primary:hover {
        background: #fb923c;
        transform: translateY(-1px);
        box-shadow: 0 12px 25px rgba(249, 115, 22, 0.5);
      }
      .btn-secondary {
        background: #475569;
        color: #f8fafc;
        border: 1px solid #64748b;
      }
      .btn-secondary:hover {
        background: #64748b;
      }
      .field {
        margin-bottom: 1rem;
      }
      label {
        display: block;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
        color: #94a3b8;
      }
      input,
      select {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        border: 1px solid #475569;
        background: #334155;
        color: #f8fafc;
        font-size: 0.95rem;
      }
      input:focus,
      select:focus {
        outline: none;
        border-color: #f97316;
        box-shadow: 0 0 0 1px rgba(249, 115, 22, 0.4);
      }
      footer {
        padding: 1rem 2rem;
        font-size: 0.8rem;
        color: #64748b;
        text-align: center;
        border-top: 1px solid #334155;
        background: #1e293b;
      }
      code {
        background: #334155;
        padding: 0.15rem 0.35rem;
        border-radius: 0.35rem;
        font-size: 0.85rem;
        color: #fb923c;
      }
      .badge {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .badge-info {
        background: rgba(56, 189, 248, 0.2);
        color: #38bdf8;
      }
      .badge-danger {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
      }
      .badge-success {
        background: rgba(34, 197, 94, 0.2);
        color: #4ade80;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th,
      td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #334155;
        text-align: left;
      }
      th {
        font-size: 0.8rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      tr:last-child td {
        border-bottom: none;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="brand">MEETEVENTS</a>
      <nav>
        <a href="/">Eventos</a>
        <a href="/admin/orders">Pedidos</a>
      </nav>
    </header>
    <main>
      <% if (typeof contentTemplate !== 'undefined') { %>
        <%- include(contentTemplate) %>
      <% } %>
    </main>
    <footer>
      MeetEvents · 2026
    </footer>
  </body>
</html>

