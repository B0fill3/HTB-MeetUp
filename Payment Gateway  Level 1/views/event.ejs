<section class="card">
  <span class="badge badge-info">Evento</span>
  <h1 style="margin-top:0.5rem;"><%= event.name %></h1>
  <p style="color:#cbd5e1;font-size:0.95rem;"><%= event.description %></p>

  <p style="font-size:0.9rem;margin-top:0.75rem;color:#94a3b8;">
    <strong>Fecha:</strong> <%= event.date %> ·
    <strong>Lugar:</strong> <%= event.location %>
  </p>

  <hr style="border:none;border-top:1px solid #334155;margin:1.5rem 0;" />

  <form method="post" action="/event/<%= event.id %>/checkout">
    <input type="hidden" name="priceID" value="<%= event.priceID %>" />
    <div class="field">
      <label for="customerName">Nombre de la persona que realiza el pedido</label>
      <input
        type="text"
        id="customerName"
        name="customerName"
        placeholder="Nombre y apellidos"
        required
      />
    </div>
    <div class="field">
      <label for="quantity">Número de entradas</label>
      <input
        type="number"
        id="quantity"
        name="quantity"
        min="1"
        value="1"
        required
      />
    </div>
    <p style="margin-bottom:1rem;font-size:0.9rem;color:#cbd5e1;">
      <% if (event.isFree) { %>
        Precio: <strong>Entrada Gratuita</strong>
      <% } else { %>
        Precio por entrada: <strong><%= event.price.toFixed(2) %> €</strong>
      <% } %>
    </p>
    <button type="submit" class="btn btn-primary">
      Ir al pago
    </button>
    <a href="/" class="btn btn-secondary" style="margin-left:0.5rem;">
      Volver
    </a>
  </form>
</section>

