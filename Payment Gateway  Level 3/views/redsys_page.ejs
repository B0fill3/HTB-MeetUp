<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Redsys Secure Payments</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: #f3f4f6;
        margin: 0;
        padding: 0;
      }
      .rs-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #e5e7eb;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .rs-logo {
        display: flex;
        align-items: center;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.95rem;
      }
      .rs-logo-mark {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        margin-right: 0.55rem;
        background: conic-gradient(
          from 160deg,
          #f97316,
          #facc15,
          #f97316,
          #fb923c
        );
        box-shadow: 0 0 0 2px rgba(15, 23, 42, 0.7);
      }
      .rs-header span {
        font-size: 0.8rem;
        color: #9ca3af;
      }
      .rs-container {
        max-width: 420px;
        margin: 2.5rem auto;
        background: #ffffff;
        border-radius: 0.75rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
        border: 1px solid #e5e7eb;
        padding: 1.5rem 1.75rem 1.75rem;
      }
      h1 {
        margin: 0;
        font-size: 1.1rem;
        color: #111827;
      }
      .rs-subtitle {
        font-size: 0.85rem;
        color: #6b7280;
        margin-top: 0.35rem;
      }
      .rs-amount-box {
        margin-top: 1rem;
        background: #eff6ff;
        border-radius: 0.75rem;
        padding: 0.75rem 0.9rem;
        border: 1px solid #bfdbfe;
        font-size: 0.9rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .rs-amount-label {
        color: #1f2937;
      }
      .rs-amount-value {
        font-weight: 700;
        color: #1d4ed8;
      }
      .rs-field {
        margin-top: 0.9rem;
      }
      label {
        display: block;
        font-size: 0.8rem;
        color: #6b7280;
        margin-bottom: 0.25rem;
      }
      input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.5rem 0.6rem;
        border-radius: 0.5rem;
        border: 1px solid #d1d5db;
        font-size: 0.9rem;
      }
      input:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.35);
      }
      .rs-row {
        display: flex;
        gap: 0.6rem;
      }
      .rs-error {
        margin-top: 0.9rem;
        background: #fef2f2;
        border-radius: 0.5rem;
        border: 1px solid #fecaca;
        padding: 0.6rem 0.7rem;
        font-size: 0.8rem;
        color: #b91c1c;
      }
      .rs-button {
        margin-top: 1.1rem;
        width: 100%;
        border: none;
        border-radius: 999px;
        padding: 0.6rem 1rem;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #ffffff;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(22, 163, 74, 0.35);
      }
      .rs-button:hover {
        filter: brightness(1.03);
      }
      .rs-footer {
        margin-top: 1.1rem;
        font-size: 0.7rem;
        color: #9ca3af;
        text-align: center;
      }
      .rs-dev {
        margin: 2rem auto 1.75rem;
        max-width: 420px;
        font-size: 0.75rem;
        color: #6b7280;
      }
      .rs-dev pre {
        margin-top: 0.4rem;
        padding: 0.6rem 0.7rem;
        background: #111827;
        color: #e5e7eb;
        border-radius: 0.5rem;
        overflow: auto;
        max-height: 180px;
        font-size: 0.7rem;
      }
      .rs-env-label {
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.7rem;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <header class="rs-header">
      <div class="rs-logo">
        <div class="rs-logo-mark"></div>
        <span>REDSYS&nbsp;SECURE&nbsp;PAYMENTS</span>
      </div>
      <span>Entorno de pruebas</span>
    </header>

    <main>
      <section class="rs-container">
        <h1>Introduzca los datos de su tarjeta</h1>
        <p class="rs-subtitle">
          Complete los datos de pago para finalizar la transacción con su
          entidad emisora.
        </p>

        <div class="rs-amount-box">
          <span class="rs-amount-label">Importe a cobrar</span>
          <span class="rs-amount-value">
            <% if (decodedParams && decodedParams.Ds_Merchant_Amount) { %>
              <%= (Number(decodedParams.Ds_Merchant_Amount) / 100).toFixed(2) %> €
            <% } else { %>
              --
            <% } %>
          </span>
        </div>

        <form method="post" action="/redsys/pay" autocomplete="off">
          <div class="rs-field">
            <label for="cardNumber">Número de tarjeta</label>
            <input
              id="cardNumber"
              name="cardNumber"
              inputmode="numeric"
              maxlength="19"
              placeholder="#### #### #### ####"
              required
            />
          </div>

          <div class="rs-row">
            <div class="rs-field" style="flex: 1;">
              <label for="expiry">Fecha caducidad (MM/AA)</label>
              <input
                id="expiry"
                name="expiry"
                placeholder="MM/AA"
                maxlength="5"
                required
              />
            </div>
            <div class="rs-field" style="flex: 0.7;">
              <label for="cvv">CVV</label>
              <input
                id="cvv"
                name="cvv"
                inputmode="numeric"
                maxlength="4"
                placeholder="***"
                required
              />
            </div>
          </div>

          <div class="rs-field">
            <label for="holder">Titular</label>
            <input
              id="holder"
              name="holder"
              placeholder="Nombre y apellidos del titular"
              required
            />
          </div>

          <!-- Mantenemos los parámetros del comercio para el laboratorio -->
          <input
            type="hidden"
            name="Ds_MerchantParameters"
            value="<%= Ds_MerchantParameters %>"
          />

          <% if (errorMessage) { %>
            <div class="rs-error">
              <strong>Error en la operación.</strong><br />
              <%= errorMessage %>
            </div>
          <% } %>

          <button type="submit" class="rs-button">
            Pagar
          </button>

          <p class="rs-footer">
            Redsys Servicios de Procesamiento de Pagos, S.A. · Transacción
            simulada en entorno de pruebas.
          </p>
        </form>
      </section>

    </main>
  </body>
</html>

